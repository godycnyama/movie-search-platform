        "type": "object",
        "properties": {
          "current_password": {
            "type": "string"
          },
          "new_password": {
            "minLength": 8,
            "pattern": "^(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^a-zA-Z0-9]).+$",
            "type": "string"
          }
        }
