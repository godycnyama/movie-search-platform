    "/api/v1/movies/search": {
      "get": {
        "tags": [
          "Movies"
        ],
        "operationId": "SearchMovies",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "top_k",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
