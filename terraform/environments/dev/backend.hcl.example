# Copy to backend.hcl (git-ignored) and fill in the bootstrap outputs, then:
#   terraform init -backend-config=backend.hcl
bucket         = "<state-bucket-name-from-bootstrap>"
key            = "movie-search/dev/terraform.tfstate"
region         = "eu-west-1"
dynamodb_table = "movie-search-terraform-locks"
encrypt        = true
