# Movie Search Platform — environment template
# Copy this file to `.env` and fill in real values:  cp .env.example .env
#
# `.env` is git-ignored and MUST NOT be committed. Never hardcode secrets in
# source or compose files — they are all read from the environment.

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=movies
POSTGRES_PASSWORD=change-me-strong-password   # REQUIRED — set a strong value
POSTGRES_DB=movies
POSTGRES_PORT=5432

# --- Embeddings ------------------------------------------------------------
# Backend selection is by ENV: local -> Ollama container (below),
# dev/prod -> Amazon Bedrock (see terraform/). Keep local for docker-compose.
ENV=local
EMBEDDINGS_PORT=8001
EMBEDDING_DIM=768                 # must match the model + pgvector column (nomic=768, Titan v2=1024)
EMBEDDING_MODEL=nomic-embed-text  # Ollama model the pipeline embeds with (768-dim)
HF_TOKEN=                         # optional; only needed for gated HF models

# --- Redis (API query cache) ------------------------------------------------
REDIS_PASSWORD=change-me-redis-password   # REQUIRED — set a strong value
REDIS_PORT=6379

# --- Data pipeline ---------------------------------------------------------
PIPELINE_BATCH_SIZE=64
PIPELINE_VERSION=0.1.0

# --- MCP server ------------------------------------------------------------
MCP_PORT=8000
MCP_TRANSPORT=sse                 # sse (local) | streamable-http (production)

# --- .NET API --------------------------------------------------------------
# The API binds strongly-typed settings sections (src/**/Settings/*.cs) via the
# ASP.NET Core `Section__Property` convention. The values below show each
# setting's default; docker-compose forwards them to the `api` service.
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# PostgresSettings — connection string is assembled from the POSTGRES_* vars above.
# RedisSettings.ConnectionString — assembled from REDIS_PASSWORD above.

# JwtSettings
JWT_ISSUER=movie-search-platform
JWT_AUDIENCE=movie-search-clients
JWT_SIGNING_KEY=change-me-at-least-32-bytes-long   # REQUIRED — long random secret (>= 32 chars)
JwtSettings__ExpiryMinutes=60                       # token lifetime in minutes (5–1440)

# RedisSettings (cache tuning)
RedisSettings__InstanceName=movie-search:           # prefix applied to every cache key
RedisSettings__DefaultTtlSeconds=300                # default entry TTL (1–86400)
RedisSettings__AbortOnConnectFail=false             # keep retrying if Redis is down at startup
RedisSettings__UseSsl=false                         # true for managed/TLS Redis

# CorsSettings — browser origins allowed to call the API (indexed array).
# Leave both unset (or empty) to grant no cross-origin access.
CorsSettings__AllowedOrigins__0=http://localhost:3000
CorsSettings__AllowedOrigins__1=http://localhost:5173

# RateLimitSettings (fixed-window, per authenticated user / IP)
RateLimitSettings__PermitLimit=60                   # requests allowed per window
RateLimitSettings__WindowSeconds=60                 # window length in seconds
RateLimitSettings__QueueLimit=0                     # extra requests queued before returning 429

# RequestTimeoutSettings
RequestTimeoutSettings__DefaultTimeoutSeconds=30    # per-request timeout in seconds (1–600)

# OtelSettings — the standard OTEL_* vars (set in docker-compose) take precedence,
# so these are only used if those are unset.
OtelSettings__ServiceName=movie-search-api
OtelSettings__OtlpEndpoint=http://jaeger:4317

# --- Observability ---------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me   # REQUIRED
JAEGER_UI_PORT=16686

# --- Embedding Atlas (bonus) ----------------------------------------------
ATLAS_PORT=7000

# --- Shared ----------------------------------------------------------------
LOG_LEVEL=INFO
