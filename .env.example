# Movie Search Platform — environment template
# Copy this file to `.env` and fill in real values:  cp .env.example .env
#
# `.env` is git-ignored and MUST NOT be committed. Never hardcode secrets in
# source or compose files — they are all read from the environment.

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=movies
POSTGRES_PASSWORD=change-me-strong-password   # REQUIRED — set a strong value
POSTGRES_DB=movies
POSTGRES_PORT=5432

# --- Embeddings ------------------------------------------------------------
EMBEDDINGS_PORT=8001
EMBEDDING_DIM=768                 # must match the embedding model + pgvector column
EMBEDDING_MODEL=nomic-embed-text  # Ollama model the pipeline embeds with (768-dim)
HF_TOKEN=                         # optional; only needed for gated HF models

# --- Redis (API query cache) ------------------------------------------------
REDIS_PASSWORD=change-me-redis-password   # REQUIRED — set a strong value
REDIS_PORT=6379

# --- Data pipeline ---------------------------------------------------------
PIPELINE_BATCH_SIZE=64
PIPELINE_VERSION=0.1.0

# --- MCP server ------------------------------------------------------------
MCP_PORT=8000
MCP_TRANSPORT=sse                 # sse (local) | streamable-http (production)

# --- .NET API --------------------------------------------------------------
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
JWT_ISSUER=movie-search-platform
JWT_AUDIENCE=movie-search-clients
JWT_SIGNING_KEY=change-me-at-least-32-bytes-long   # REQUIRED — long random secret

# --- Observability ---------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me   # REQUIRED
JAEGER_UI_PORT=16686

# --- Embedding Atlas (bonus) ----------------------------------------------
ATLAS_PORT=7000

# --- Shared ----------------------------------------------------------------
LOG_LEVEL=INFO
